{
  "schedule": {
    "time": "11:00",
    "timezone": "Asia/Bangkok",
    "utc_hour": 4,
    "utc_minute": 0
  },
  "content_modules": {
    "team_ranking": {
      "image_generator": "generate_report_image",
      "description": "ภาพรวมจัดอันดับทีม"
    },
    "individual_ranking": {
      "image_generator": "generate_team_image",
      "per_team": true,
      "description": "จัดอันดับรายบุคคลแยกตามทีม"
    },
    "result_metrics": {
      "description": "ตัวชี้วัดผลลัพธ์",
      "metrics_by_role": {
        "CC": ["revenue_usd", "referral_share"],
        "SS": ["narrow_leads"],
        "LP": ["narrow_wide_leads"]
      }
    },
    "achievement_metrics": {
      "description": "ตัวชี้วัดการบรรลุเป้า",
      "metrics_by_role": {
        "CC": ["leads_rate", "appointment_rate", "showup_rate", "order_rate", "revenue_rate", "aov_rate", "checkin_rate"],
        "SS": ["leads_rate"],
        "LP": ["leads_rate", "checkin_rate"]
      }
    },
    "process_metrics": {
      "description": "ตัวชี้วัดกระบวนการ (ลงทะเบียน/นัดหมาย/เข้าเรียน/ติดต่อ/เช็คอิน/แนะนำ)"
    },
    "efficiency_metrics": {
      "description": "ตัวชี้วัดประสิทธิภาพ (อัตราแปลง/อัตราติดต่อ/สัดส่วนแนะนำ)"
    },
    "service_metrics": {
      "description": "ตัวชี้วัดบริการ (โทรก่อน/หลังชำระ: จำนวนโทร/ติดต่อได้/มีประสิทธิผล)"
    },
    "action_items": {
      "format": "markdown",
      "description": "คำแนะนำการดำเนินงาน (ติดตาม/นักเรียนสำคัญ)"
    },
    "honor_ranking": {
      "description": "เกียรติยศเช็คอิน (100%/95%/85% สามระดับ)"
    },
    "cc_enc_warning": {
      "description": "แจ้งเตือนคอก CC (ความเสี่ยงโอนย้าย)",
      "cc_only": true
    },
    "student_improvement": {
      "format": "markdown",
      "description": "นักเรียนพัฒนาการ Top5 + นักเรียนศักยภาพสูงที่หลับอยู่（学员打卡进步 Top5 + 沉睡高潜统计）",
      "api": "/api/checkin/student-analysis?limit=5",
      "fields": ["improvement_ranking", "tags_summary"]
    },
    "team_comprehensive": {
      "per_team": true,
      "description": "每组多维达成卡：团队汇总(业绩/付费/Leads/打卡率) + 每人指标表格",
      "data_sources": ["/api/checkin/ranking", "/api/cc-performance"],
      "cc_only_note": "仅 CC 通道使用，SS/LP 用 individual_ranking"
    },
    "unchecked_ids": {
      "format": "markdown",
      "description": "按组→CC分组的未打卡学员ID列表，方便复制跟进",
      "data_source": "/api/checkin/followup"
    }
  },
  "scope": "narrow",
  "scope_description": "通知只发送窄口径数据（CC/SS/LP，无运营），来源 config.json enclosure_role_narrow",
  "routing": {
    "ops": ["team_ranking", "result_metrics", "achievement_metrics", "action_items", "cc_enc_warning"],
    "cc_detail": ["tl_overview", "team_checkin_combined"],
    "cc_overview": ["tl_overview"],
    "role_detail": ["team_ranking", "individual_ranking"]
  },
  "role_metrics": {
    "CC": {
      "enclosure": "M0-M2",
      "scope": "narrow+wide, responsible for conversion",
      "result": ["付费金额", "转介绍占比"],
      "achievement": ["leads达成率", "预约达成率", "出席达成率", "单量达成率", "业绩达成率", "客单价达成率", "打卡率"],
      "process": ["转介绍注册数", "预约数", "出席数", "客单价", "付费数", "触达数", "打卡数", "带新数", "带货数"],
      "efficiency": ["触达率", "带货比", "带新系数", "注册付费率", "预约付费率", "出席付费率"],
      "wide_process": ["打卡数"],
      "service": {
        "pre_payment": ["外呼数", "接通数", "有效接通数"],
        "post_payment": ["外呼数", "接通数", "有效接通数"]
      }
    },
    "SS": {
      "enclosure": "M3 narrow only (follows enclosure_role_narrow config)",
      "scope": "narrow leads only",
      "result": ["窄口leads数"],
      "achievement": ["leads达成率"],
      "process": ["转介绍注册数", "触达数", "带新数"],
      "efficiency": ["触达率", "带新系数"],
      "service": {
        "pre_payment": ["外呼数", "接通数", "有效接通数"],
        "post_payment": ["外呼数", "接通数", "有效接通数"]
      }
    },
    "LP": {
      "enclosure": "M4+ narrow (follows enclosure_role_narrow config)",
      "scope": "narrow leads",
      "result": ["窄宽leads数"],
      "achievement": ["leads达成率", "打卡率"],
      "process": ["转介绍注册数", "触达数", "带新数"],
      "efficiency": ["触达率", "带新系数"],
      "wide_process": ["打卡数"],
      "service": {
        "pre_payment": ["外呼数", "接通数", "有效接通数"],
        "post_payment": ["外呼数", "接通数", "有效接通数"]
      }
    }
  }
}
